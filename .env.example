# App identity — change APP_NAME here to rename everywhere
APP_NAME=Juncture
BASE_URL=http://localhost:3000
PORT=3000

# Where the SQLite DB and uploaded media live
# On assemblyserver, set this to an absolute path with plenty of disk space
DATA_DIR=./data

# Session secret — generate a long random string, never commit the real value
SESSION_SECRET=change-me-to-a-long-random-string-at-least-64-chars

# Admin bootstrap — used ONLY on first boot to create Ryan's admin account
# After first boot, remove these or leave blank; the route disables itself once used
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-to-something-strong
