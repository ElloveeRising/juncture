# App identity — change APP_NAME here to rename everywhere
APP_NAME=Juncture
# Public URL. In production set this to your real domain (e.g. https://juncture.example.com).
# It makes cookies Secure and allow-lists the domain for form submissions.
BASE_URL=http://localhost:3000
PORT=3000

# Where the SQLite DB and uploaded media live
# On the server, set this to an absolute path with plenty of disk space (e.g. /opt/juncture/data)
DATA_DIR=./data

# Session secret — generate a long random string, never commit the real value
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string-at-least-64-chars

# Admin bootstrap — used ONLY on first boot to create the very first admin.
# After first boot, remove ADMIN_BOOTSTRAP_PASSWORD; it disables itself once an admin exists.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-to-something-strong

# Founding trio — comma-separated emails that come in as co-equal arbiters
# (full admin power) the moment they sign up. No one has to promote anyone.
# Use the real emails Ryan, Jesse, and Ali will sign up with.
FOUNDER_EMAILS=ryan@example.com,jesse@example.com,ali@example.com

# Optional: extra origins allowed to submit forms, if you serve from more than
# one hostname (comma-separated). BASE_URL's host is always allowed.
# ALLOWED_ORIGINS=
